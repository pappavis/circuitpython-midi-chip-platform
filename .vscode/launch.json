{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCP: Diagnose Host Skeleton",
      "type": "debugpy",
      "request": "launch",
      "module": "midi_chip_platform",
      "args": [
        "diagnose"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "MCP: Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal"
    }
  ]
}
