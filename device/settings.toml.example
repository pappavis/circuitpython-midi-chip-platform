# Copy this file to CIRCUITPY/settings.toml and replace only the placeholders you need.
# Never commit the resulting settings.toml file.

WIFI_SSID = "replace-with-your-network-name"
WIFI_PASSWORD = "replace-with-your-network-password"
WEB_AP_PASSWORD = "replace-with-a-strong-access-point-password"

# Optional public overrides. Runtime/CLI overrides will take precedence later.
AUDIO_BACKEND = "i2s-max98357a-mono"
I2S_BIT_CLOCK = "IO5"
I2S_WORD_SELECT = "IO3"
I2S_DATA = "IO7"
AUDIO_MASTER_GAIN = "0.08"
AUDIO_MAXIMUM_MASTER_GAIN = "0.25"
AUDIO_STARTUP_MUTED = "true"
AUDIO_AMPLIFIER_GAIN_DB = "9.0"
AUDIO_GAIN_PIN_PROFILE = "floating-9db"
AUDIO_SHUTDOWN_MODE = "software-mute"
AUDIO_OUTPUT_LOAD = "speaker-4-8-ohm"

# Default MVP synth runtime. Set D1_RUNTIME_ENABLED = "false" when you only want
# boot/config diagnostics and no continuous synth loop.
D1_RUNTIME_ENABLED = "true"
D1_FAST_BOOT_MODE = "true"
D1_WAVEFORM = "square"
D1_SAMPLE_RATE = 16000
D1_FRAMES_PER_BLOCK = 128
D1_AMPLITUDE = "0.5"
D1_MAX_BLOCKS = 0
D1_IDLE_SLEEP_SECONDS = "0.001"
D1_MINIMUM_NOTE_SECONDS = "0.05"
D1_MINIMUM_NOTE_VELOCITY = 64
D1_AUDITION_MASTER_GAIN = "0.25"
D1_STREAM_ACTIVE_BLOCKS = "false"
D1_AUDITION_TONE_AMPLITUDE = 8192
D1_EVENT_LOGGING = "none"
D1_TIMING_MARKER_ENABLED = "true"
D1_TIMING_MARKER_PIN = "IO9"

# P0 realtime baseline spike. Enable this temporarily when MCP-US-077 is under
# test. It bypasses the D1 core and SafeAudioOutput and plays one precomputed
# I2S tone on every USB-MIDI NoteOn.
REALTIME_BASELINE_ENABLED = "false"
REALTIME_BASELINE_SAMPLE_RATE = 16000
REALTIME_BASELINE_FREQUENCY_HZ = "440.0"
REALTIME_BASELINE_AMPLITUDE = 4096
REALTIME_BASELINE_TONE_SECONDS = "0.12"
REALTIME_BASELINE_MAX_NOTE_EVENTS = 0
REALTIME_BASELINE_TIMEOUT_SECONDS = "0.0"
REALTIME_BASELINE_IDLE_SLEEP_SECONDS = "0.0"
REALTIME_BASELINE_EVENT_LOGGING = "none"
REALTIME_BASELINE_BOOT_AUDITION_SECONDS = "0.6"

# P0 persistent synthio audio graph spike. Enable this temporarily when
# MCP-US-079 is under test. It opens I2S once and keeps synthio running; MIDI
# NoteOn/Off only calls synth.press/release.
SYNTHIO_BASELINE_ENABLED = "false"
SYNTHIO_BASELINE_SAMPLE_RATE = 16000
SYNTHIO_BASELINE_CHANNEL_COUNT = 1
SYNTHIO_BASELINE_MAX_NOTE_EVENTS = 0
SYNTHIO_BASELINE_TIMEOUT_SECONDS = "0.0"
SYNTHIO_BASELINE_IDLE_SLEEP_SECONDS = "0.001"
SYNTHIO_BASELINE_EVENT_LOGGING = "summary"
SYNTHIO_BASELINE_BOOT_AUDITION_NOTE = 69
SYNTHIO_BASELINE_BOOT_AUDITION_SECONDS = "0.6"
SYNTHIO_BASELINE_GATE_SECONDS = "0.12"
SYNTHIO_BASELINE_SCAN_ALL_MIDI_PORTS = "true"

# P0 USB-MIDI routing diagnostic. Enable this temporarily when Logic/CoreMIDI
# routing must be measured without any synth audio path. Expect serial
# MIDI_ROUTING_EVENT lines, not sound.
MIDI_ROUTING_DIAGNOSTIC_ENABLED = "false"
MIDI_ROUTING_DIAGNOSTIC_SCAN_ALL_PORTS = "true"
MIDI_ROUTING_DIAGNOSTIC_MAX_EVENTS = 16
MIDI_ROUTING_DIAGNOSTIC_TIMEOUT_SECONDS = "60.0"
MIDI_ROUTING_DIAGNOSTIC_IDLE_SLEEP_SECONDS = "0.001"
MIDI_ROUTING_DIAGNOSTIC_EVENT_LOGGING = "summary"
MIDI_ROUTING_DIAGNOSTIC_HEARTBEAT_SECONDS = "2.0"
MIDI_ROUTING_DIAGNOSTIC_MAX_TRACE_LINES = 96

# Layered HIL diagnostic framework. Disabled by default; when enabled, it prints
# exactly one HIL boot summary and does not start the D1 performance runtime.
HIL_DIAGNOSTIC_ENABLED = "false"
HIL_EXPECTED_VERSION = ""
HIL_EXPECTED_RELEASE_DATE = ""
HIL_EXPECTED_STORY = ""
HIL_EXPECTED_CODE_PY_SHA256 = ""
HIL_EXPECTED_BOOT_PY_SHA256 = ""
HIL_RAW_MIDI_MAX_PACKETS = 8
HIL_RAW_MIDI_TIMEOUT_SECONDS = "0.25"
HIL_PARSER_MAX_MESSAGES = 8
HIL_PARSER_TIMEOUT_SECONDS = "0.25"

# Optional, bounded USB-MIDI Note On/Off acceptance diagnostic.
# Leave disabled for normal startup. Enable temporarily, then restart the board.
# CircuitPython 10.0.x os.getenv settings support strings and integers.
MIDI_DIAGNOSTIC_ENABLED = "false"
MIDI_DIAGNOSTIC_MAX_EVENTS = 8
MIDI_DIAGNOSTIC_TIMEOUT_SECONDS = 60
MIDI_DIAGNOSTIC_POLL_INTERVAL_SECONDS = "0.01"
MIDI_INPUT_PORT_INDEX = 0
